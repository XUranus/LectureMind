# Tencent Cloud COS (for audio file hosting, used by ASR)
COS_SECRECT_ID='Tencent-COS-Secrent-ID'
COS_SECRECT_KEY='Tencent-COS-Secrent-Key'
COS_REGION='ap-singapore' # e.g., ap-guangzhou, ap-singapore
COS_BUCKET='polyu-video-xxxx'

# Alibaba DashScope API key (for ASR + LLM)
DASHSCOPE_API_KEY='sk-xxxxxxxxxxxxxxxxxx'

# LLM Configuration (optional, defaults shown)
# LLM_MODEL='qwen2.5-7b-instruct'
# LLM_API_BASE='https://dashscope.aliyuncs.com/compatible-mode/v1'

# ChromaDB Configuration (optional, defaults shown)
# CHROMA_PERSIST_DIR='./media/chromadb'
