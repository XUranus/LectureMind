# Tencent Cloud COS (for audio file hosting, used by ASR)
COS_SECRECT_ID='Tencent-COS-Secrent-ID'
COS_SECRECT_KEY='Tencent-COS-Secrent-Key'
COS_REGION='ap-singapore' # e.g., ap-guangzhou, ap-singapore
COS_BUCKET='LectureMind-xxxx'

# Alibaba DashScope API key (for ASR + LLM)
DASHSCOPE_API_KEY='sk-xxxxxxxxxxxxxxxxxx'

LLM_API_BASE='https://dashscope.aliyuncs.com/compatible-mode/v1'

# Task pipeline LLM
# LLM_MODEL='qwen2.5-7b-instruct'

# RAG chat LLM
# CHAT_MODEL=qwen3-max

# Slide OCR vision LLM
# VL_MODEL=qwen2.5-vl-72b-instruct

# ── Server ───────────────────────────────────────────────────────────────────
# Port for the backend API (default: 8000)
# BACKEND_PORT=8000

# Port for the frontend nginx server (default: 3000)
# FRONTEND_PORT=3000

# Comma-separated list of allowed hosts (default: localhost,127.0.0.1)
# ALLOWED_HOSTS=localhost,127.0.0.1

# CORS origins that may call the API (default: http://localhost:3000)
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# Django secret key – CHANGE THIS in production!
# SECRET_KEY=django-insecure-change-me

# ── Storage paths ────────────────────────────────────────────────────────────
# Root directory for all uploaded/generated media (default: <BASE_DIR>/media)
# MEDIA_ROOT=/var/lib/lecturemind/media

# URL prefix served by Django for media files (default: /media/)
# MEDIA_URL=/media/

# Sub-directories inside MEDIA_ROOT (relative paths resolved against MEDIA_ROOT)
# MEDIA_AUDIO_DIR=audio
# MEDIA_STREAMS_DIR=streams
# MEDIA_THUMBNAILS_DIR=thumbnails

# SQLite database file path (default: <BASE_DIR>/db.sqlite3)
# DB_PATH=/var/lib/lecturemind/db.sqlite3

# Log directory (default: <BASE_DIR>/logs)
# LOG_DIR=/var/log/lecturemind

# ChromaDB persistent directory (default: <MEDIA_ROOT>/chromadb)
# CHROMA_PERSIST_DIR=/var/lib/lecturemind/media/chromadb
